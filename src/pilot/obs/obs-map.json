    "bottomControls": {
      "label": "Bottom Controls",
      "a11yRole": "panel",
      "a11yName": null,
      "position": "bottom-center",
      "controls": ["startRecordingBtn", "startVirtualCameraBtn"]
    }
  },
  "controls": {
