    "sceneRemoveBtn":         { "a11yRole": "push button", "a11yName": "Remove",               "region": "scenes",          "ocrFallback": "-",                    "coord": [50,   1033] },
    "sourceAddBtn":           { "a11yRole": "push button", "a11yName": "Add",                  "region": "sources",         "ocrFallback": "+",                    "coord": [330,  1028] },
