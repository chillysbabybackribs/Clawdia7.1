    "settingsBtn":            { "a11yRole": "push button", "a11yName": "Settings",             "region": "controls",        "ocrFallback": "Settings",             "coord": [1421, 955] },
    "settingsOkBtn":          { "a11yRole": "push button", "a11yName": "OK",                   "region": "settingsButtons", "ocrFallback": "OK" },
    "settingsCloseBtn":       { "a11yRole": "push button", "a11yName": "Close",                "region": "settingsButtons", "ocrFallback": "Close" },
